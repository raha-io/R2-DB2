# R2-DB2 Analyst — environment template
# Copy to `.env` and fill in OPENROUTER__API_KEY at minimum.
#
# Hosts default to `localhost` so the same .env works when you run the app
# directly via `uv run uvicorn main:app` against the compose-forwarded ports.
# When running inside `docker compose up`, the compose file overrides hostnames
# to the internal service names (clickhouse, postgres, redis, qdrant).

# ── Application ──
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── OpenRouter LLM ──
# Get a key at https://openrouter.ai/keys
OPENROUTER__API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER__BASE_URL=https://openrouter.ai/api/v1
OPENROUTER__MODEL=anthropic/claude-sonnet-4
OPENROUTER__FALLBACK_MODEL=openai/gpt-4o-mini
OPENROUTER__TEMPERATURE=0.0
OPENROUTER__MAX_TOKENS=4096
OPENROUTER__TIMEOUT=60

# ── ClickHouse (analytics warehouse) ──
# Compose seeds via the `clickhouse-init` service, so leave SEED_ON_STARTUP=false.
CLICKHOUSE__HOST=localhost
CLICKHOUSE__PORT=8123
CLICKHOUSE__DATABASE=analytics
CLICKHOUSE__USER=default
CLICKHOUSE__PASSWORD=
CLICKHOUSE__SECURE=false
CLICKHOUSE__SEED_ON_STARTUP=false

# ── Postgres (LangGraph checkpointer) ──
POSTGRES__HOST=localhost
POSTGRES__PORT=5432
POSTGRES__DATABASE=r2_db2_checkpoints
POSTGRES__USER=r2-db2
POSTGRES__PASSWORD=r2_db2_secret

# ── Redis (caching) ──
REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__DB=0

# ── Qdrant (semantic search) ──
QDRANT__HOST=localhost
QDRANT__PORT=6333
QDRANT__COLLECTION=r2_db2_memory

# ── Server ──
SERVER__HOST=0.0.0.0
SERVER__PORT=8000
SERVER__WORKERS=1

# ── Observability (Langfuse) ──
LANGFUSE__ENABLED=false
LANGFUSE__PUBLIC_KEY=
LANGFUSE__SECRET_KEY=
LANGFUSE__HOST=https://cloud.langfuse.com

# ── Graph ──
# When true, the graph pauses for human approval before running SQL.
GRAPH__HITL_ENABLED=false

# ── Report output (optional overrides) ──
# REPORT__OUTPUT_DIR=reports
# REPORT__DEFAULT_FORMATS=["pdf","plotly_html","csv","json"]
# REPORT__PDF_PAGE_SIZE=A4
# REPORT__PDF_MARGIN=20mm
