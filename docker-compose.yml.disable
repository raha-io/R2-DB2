
services:
  # ── Application ──
  app:
    build:
      context: .
      dockerfile: Dockerfile
      args:
        PUBLIC_IMAGE_REGISTRY: ${PUBLIC_IMAGE_REGISTRY}
        LOCAL_ARTIFACTORY_ADDRESS: ${LOCAL_ARTIFACTORY_ADDRESS}
        PIP_REPO_URL: ${PIP_REPO_URL}
    ports:
      - "${SERVER__PORT:-8000}:8000"
    env_file:
      - .env
    depends_on:
      clickhouse:
        condition: service_healthy
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      clickhouse-init:
        condition: service_completed_successfully
    volumes:
      - ./artifacts:/app/artifacts
    restart: unless-stopped
    networks:
      - r2-db2-net
    extra_hosts:
      - "internal-registry:127.0.0.1"

  # ── ClickHouse ──
  clickhouse:
    image: clickhouse/clickhouse-server:26.2
    ports:
      - "8123:8123"
      - "9000:9000"
    environment:
      CLICKHOUSE_DB: analytics
      CLICKHOUSE_USER: default
      CLICKHOUSE_PASSWORD: ""
      CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT: 1
    volumes:
      - clickhouse-data:/var/lib/clickhouse
      - clickhouse-logs:/var/log/clickhouse-server
    healthcheck:
      test: ["CMD", "clickhouse-client", "--query", "SELECT 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    restart: unless-stopped
    networks:
      - r2-db2-net

  # ── ClickHouse Init (one-shot seeder) ──
  clickhouse-init:
    build:
      context: .
      dockerfile: Dockerfile
      args:
        PUBLIC_IMAGE_REGISTRY: ${PUBLIC_IMAGE_REGISTRY}
        LOCAL_ARTIFACTORY_ADDRESS: ${LOCAL_ARTIFACTORY_ADDRESS}
        PIP_REPO_URL: ${PIP_REPO_URL}
    command: ["python", "-c", "from integrations.clickhouse.seed import seed_clickhouse_sync; from config.settings import get_settings; seed_clickhouse_sync(get_settings().clickhouse)"]
    env_file:
      - .env
    depends_on:
      clickhouse:
        condition: service_healthy
    restart: "no"
    networks:
      - r2-db2-net
    extra_hosts:
      - "internal-registry:127.0.0.1"

  # ── PostgreSQL (LangGraph checkpointer) ──
  postgres:
    image: postgres:18.1
    ports:
      - "5432:5432"
    environment:
      POSTGRES_DB: r2_db2_checkpoints
      POSTGRES_USER: r2-db2
      POSTGRES_PASSWORD: r2_db2_secret
    volumes:
      - postgres-data:/var/lib/postgresql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U r2-db2 -d r2_db2_checkpoints"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    restart: unless-stopped
    networks:
      - r2-db2-net

  # ── Redis (caching) ──
  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    volumes:
      - redis-data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped
    networks:
      - r2-db2-net

  # ── Qdrant (semantic search) ──
  qdrant:
    image: qdrant/qdrant:latest
    ports:
      - "6333:6333"
      - "6334:6334"
    volumes:
      - qdrant-data:/qdrant/storage
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:6333/healthz"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    restart: unless-stopped
    networks:
      - r2-db2-net

  openwebui:
    image: ghcr.io/open-webui/open-webui:v0.8.5
    ports:
      - "3000:8080"
    volumes:
      - open-webui:/app/backend/data
    networks:
      - r2-db2-net
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:8080/health"]
      interval: 15s
      timeout: 10s
      retries: 5
      start_period: 30s

volumes:
  clickhouse-data:
  clickhouse-logs:
  postgres-data:
  redis-data:
  qdrant-data:
  open-webui:

networks:
  r2-db2-net:
    driver: bridge
